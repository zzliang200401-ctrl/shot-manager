{
  "name": "shot-manager-backend",
  "version": "1.0.0",
  "description": "Local Shot Management System - Backend API",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "pkg . --out-path ../dist-exe"
  },
  "pkg": {
    "scripts": "*.js",
    "assets": "../frontend/**/*",
    "targets": ["node18-win-x64"],
    "outputPath": "../dist-exe"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "sqlite3": "^5.1.6",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "pkg": "^5.8.1"
  }
}